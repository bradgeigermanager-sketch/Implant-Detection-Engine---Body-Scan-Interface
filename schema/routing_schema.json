{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.org/schema/routing.schema.json",
  "title": "ImplantDetectionRouting",
  "type": "object",
  "required": ["routes"],
  "properties": {
    "routes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["onVerdict", "targets"],
        "properties": {
          "onVerdict": {
            "type": "string",
            "enum": [
              "NoImplantDetected",
              "BenignImplantDetected",
              "SuspiciousImplantDetected",
              "HighRiskImplantDetected"
            ]
          },
          "targets": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["role", "action"],
              "properties": {
                "role": {
                  "type": "string",
                  "enum": [
                    "Operator",
                    "SecurityAnalyst",
                    "MedicalReviewer",
                    "ForensicInvestigator",
                    "MissionController"
                  ]
                },
                "action": {
                  "type": "string"
                },
                "priority": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 5
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
